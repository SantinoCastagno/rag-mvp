# Google API Key para acceder a Gemini.
# Puedes obtener una en https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Directorio donde ChromaDB almacenará los datos de forma persistente.
# Por defecto es "./data/chroma_db"
# CHROMA_PERSIST_DIRECTORY=./data/my_chroma_db

# Nombre del modelo de Gemini a utilizar.
# Por defecto es "gemini-2.5-flash-lite"
# GEMINI_MODEL_NAME=gemini-2.5-flash-lite

# Nombre del proyecto para Arize Phoenix.
# Por defecto es "gemini-rag-lab"
# PHOENIX_PROJECT_NAME=gemini-rag-lab
